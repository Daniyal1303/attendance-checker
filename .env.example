# Supabase Postgres connection string used by Prisma.
# Get it from: Supabase Dashboard > Project Settings > Database > Connection string (URI).
# Use the pooled connection (port 6543) for the app; for migrations use the direct URL (port 5432).
DATABASE_URL="postgresql://postgres:<password>@<host>:5432/postgres?schema=public"

# Supabase Auth (admin login). From: Dashboard > Project Settings > API.
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon-public-key>"

# Admin logs in with a username; it is mapped to <username>@AUTH_EMAIL_DOMAIN as the
# Supabase Auth identifier. Create the admin user in Dashboard > Authentication > Users
# with email "<username>@<this-domain>" and a password (disable email confirmation).
AUTH_EMAIL_DOMAIN="attendo.local"
