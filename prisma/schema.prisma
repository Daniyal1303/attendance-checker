// Prisma schema — see DOCUMENT.md for the domain model.
// DB URL is configured in prisma.config.ts (loaded from .env via dotenv).

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String             @id @default(cuid())
  firstName  String
  lastName   String
  email      String?            @unique
  phone      String?
  createdAt  DateTime           @default(now())
  attendance AttendanceRecord[]

  @@map("users")
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
}

model AttendanceRecord {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime         @db.Date
  status    AttendanceStatus
  createdAt DateTime         @default(now())

  @@unique([userId, date])
  @@index([date])
  @@map("attendance_records")
}
